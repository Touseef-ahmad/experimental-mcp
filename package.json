{
  "name": "openai-agents-mcp",
  "version": "2.0.0",
  "description": "NestJS + OpenAI Agents SDK MCP proof-of-concept server",
  "type": "module",
  "main": "dist/src/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/main.js",
    "dev": "ts-node --esm src/main.ts",
    "demo:build": "tsc -p tsconfig.demos.json",
    "demo": "npm run demo:build && node dist-demos/demos/demo-runner.js",
    "demo:one": "npm run demo:build && node dist-demos/demos/demo-runner.js",
    "client:build": "tsc -p tsconfig.scripts.json",
    "client": "npm run build && npm run client:build && node dist-scripts/scripts/mcp-client.js",
    "test": "echo \"No tests yet\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@nestjs/common": "^11.1.27",
    "@nestjs/core": "^11.1.27",
    "@openai/agents": "^0.11.7",
    "dotenv": "^17.4.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
