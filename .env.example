# Provider: openai | ollama
MODEL_PROVIDER=ollama

# OpenAI config (required only when MODEL_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Ollama config (used when MODEL_PROVIDER=ollama)
# Use a tool-capable model: qwen2.5:1.5b, llama3.1, mistral, qwen2.5
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:1.5b
